          "rawSql": "SELECT \n  p.name AS \"prodotto\",\n  SUM(i.quantity) AS \"stock_attuale\",\n  p.reorder_threshold AS \"soglia\"\nFROM Inventory i\nJOIN Products p ON i.product_id = p.product_id\nGROUP BY p.product_id, p.name, p.reorder_threshold\nHAVING SUM(i.quantity) < p.reorder_threshold\nORDER BY stock_attuale ASC;",
          "refId": "A",
